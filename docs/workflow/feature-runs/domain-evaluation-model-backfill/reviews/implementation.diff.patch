+    const selectedDefinitions = await tx.definition.findMany({
+      where: {
+        domainId: evaluation.domainId,
+        deletedAt: null,
+        id: { in: selectedDefinitionIds },
+      },
+      select: {
+        id: true,
+        name: true,
+        parentId: true,
+        version: true,
+        createdAt: true,
+        updatedAt: true,
+        content: true,
