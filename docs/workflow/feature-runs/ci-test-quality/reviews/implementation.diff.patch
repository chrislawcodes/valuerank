+      </MemoryRouter>
+    );
+
+    expect(screen.getByLabelText('Vignette')).toBeInTheDocument();
+
+    await userEvent.selectOptions(screen.getByLabelText('Vignette'), 'run-2');
+    expect(onSingleVignetteChange).toHaveBeenCalledWith('run-2');
+  });
+});
