+import { AnalysisPanelHarness, createMockAnalysis } from './analysisPanel.fixtures';
+import { useAnalysis } from '../../../src/hooks/useAnalysis';
+
+vi.mock('../../../src/hooks/useAnalysis', () => ({
+  useAnalysis: vi.fn(),
+}));
+
